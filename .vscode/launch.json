{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Start (Scraper)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["tsx", "simple-scraper/simple-scraper.ts"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Analyze",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["tsx", "analyzer/analyze.ts"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Export Top Posts",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["tsx", "analyzer/export-top-posts.ts"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    }
  ]
}
